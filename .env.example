# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# Database
DB_USER=mealplanner
DB_PASSWORD=changeme
DB_NAME=mealplanner

# Auth — generate a long random string, e.g.: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_secret

# Strava Integration (optional — leave empty to hide Strava UI)
# Create an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost/api/strava/callback
